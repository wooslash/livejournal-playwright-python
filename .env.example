# Copy this file to `.env` and fill in your real LiveJournal credentials.
# `.env` is git-ignored and must never be committed.

# IMPORTANT: this is the LiveJournal *username* (the <name> in
# <name>.livejournal.com), NOT your email. Email is rejected as "Username not found".
LJ_USERNAME=your_livejournal_username
LJ_PASSWORD=your_livejournal_password

# --- Optional overrides (safe defaults are used if omitted) ---

# Post title (= author name). Default: "Dmitriy Shin".
POST_TITLE=Dmitriy Shin

# UI language: En | Ru. Default: En. Sets the browser context locale.
LANGUAGE=En

# Run without a visible window. Default: false.
HEADLESS=false

# Max seconds for any single auto-wait. Default: 30.
TIMEOUT_SECONDS=30

# NOTE: the browser (chromium | firefox | webkit) is chosen via the pytest flag
#   pytest --browser firefox
# not via this file.
